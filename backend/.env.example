NEXTCLOUD_BASE_URL=http://localhost:8080
NEXTCLOUD_USERNAME=admin
NEXTCLOUD_APP_PASSWORD=your-app-password-here

# 테넌트 → Nextcloud 그룹 매핑 방식
# tenantId를 Nextcloud 그룹 ID로 바로 쓴다고 가정 (예: tenantId = "company-a" → groupId = "company-a")
# 필요하면 prefix를 줄 수 있음 (예: "tenant-" + tenantId)
NEXTCLOUD_TENANT_GROUP_PREFIX=

PORT=3000
